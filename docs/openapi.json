{
  "openapi": "3.0.3",
  "info": {
    "title": "Lifelines Project API",
    "description": "REST API for a directory of volunteer mental health providers. Users authenticate via Google OAuth and register as a Client (seeking support) or a Lifeliner (volunteer provider). Authentication is cookie-based: a signed HttpOnly `access_token` cookie is set on login and read on every protected request.",
    "version": "0.0.1"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "access_token",
        "description": "Signed HttpOnly cookie set by `GET /auth/google/callback`. Send requests with `credentials: 'include'` (fetch) or `withCredentials: true` (axios)."
      }
    },
    "schemas": {
      "Role": {
        "type": "string",
        "enum": ["CLIENT", "LIFELINER"],
        "description": "CLIENT — person seeking support. LIFELINER — volunteer mental health provider."
      },
      "AgeGroup": {
        "type": "string",
        "enum": ["TEENS", "YOUNG_ADULTS", "ADULTS", "SENIORS"],
        "description": "TEENS: 13–17 | YOUNG_ADULTS: 18–25 | ADULTS: 26–64 | SENIORS: 65+"
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "cm9abc123" },
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "role": { "$ref": "#/components/schemas/Role" }
        },
        "required": ["id", "email", "role"]
      },
      "PublicLifeliner": {
        "type": "object",
        "description": "Lifeliner fields safe for public consumption. Never includes full_name, private_picture, or user_id.",
        "properties": {
          "id": { "type": "string", "example": "cm9xyz789" },
          "display_name": { "type": "string", "example": "Alex M." },
          "age": { "type": "integer", "minimum": 18, "example": 29 },
          "profile_picture": {
            "type": "string",
            "format": "uri",
            "nullable": true,
            "example": "/uploads/public/profile-pictures/cm9abc123-1711900000000.jpg"
          },
          "about_me": {
            "type": "string",
            "example": "I'm a trained listener who loves supporting young adults through anxiety."
          },
          "age_groups": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AgeGroup" },
            "example": ["YOUNG_ADULTS", "ADULTS"]
          },
          "created_at": { "type": "string", "format": "date-time" }
        },
        "required": [
          "id",
          "display_name",
          "age",
          "profile_picture",
          "about_me",
          "age_groups",
          "created_at"
        ]
      },
      "Lifeliner": {
        "type": "object",
        "description": "Full lifeliner record returned to the owner. Includes private fields never exposed publicly.",
        "allOf": [
          { "$ref": "#/components/schemas/PublicLifeliner" },
          {
            "type": "object",
            "properties": {
              "user_id": { "type": "string", "example": "cm9abc123" },
              "full_name": {
                "type": "string",
                "example": "Alexandra Martinez"
              },
              "private_picture": {
                "type": "string",
                "description": "Path to verification photo. Use `GET /lifeliners/private/verification-photo` to stream the file.",
                "example": "/lifeliners/private/verification-photo"
              },
              "updated_at": { "type": "string", "format": "date-time" }
            },
            "required": ["user_id", "full_name", "private_picture", "updated_at"]
          }
        ]
      },
      "CreateLifelinerBody": {
        "type": "object",
        "properties": {
          "full_name": { "type": "string", "example": "Alexandra Martinez" },
          "display_name": { "type": "string", "example": "Alex M." },
          "age": {
            "type": "integer",
            "minimum": 18,
            "maximum": 120,
            "example": 29
          },
          "about_me": {
            "type": "string",
            "example": "I'm a trained listener who loves supporting young adults."
          },
          "age_groups": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AgeGroup" },
            "minItems": 1,
            "example": ["YOUNG_ADULTS", "ADULTS"]
          }
        },
        "required": ["full_name", "display_name", "age", "about_me", "age_groups"]
      },
      "UpdateLifelinerBody": {
        "type": "object",
        "description": "All fields are optional. Only provided fields are updated.",
        "properties": {
          "full_name": { "type": "string" },
          "display_name": { "type": "string" },
          "age": { "type": "integer", "minimum": 18, "maximum": 120 },
          "about_me": { "type": "string" },
          "age_groups": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AgeGroup" },
            "minItems": 1
          }
        }
      },
      "SelectRoleBody": {
        "type": "object",
        "properties": {
          "role": { "$ref": "#/components/schemas/Role" }
        },
        "required": ["role"]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer", "example": 400 },
          "message": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" },
                "example": [
                  "age must not be less than 18",
                  "age_groups must contain at least 1 elements"
                ]
              }
            ]
          },
          "error": { "type": "string", "example": "Bad Request" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer" },
          "message": { "type": "string" },
          "error": { "type": "string" }
        }
      },
      "PaginatedLifeliners": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PublicLifeliner" }
          },
          "total": {
            "type": "integer",
            "description": "Total number of lifeliners matching the active filters.",
            "example": 42
          },
          "page": {
            "type": "integer",
            "description": "Current page number (1-based).",
            "example": 1
          },
          "limit": {
            "type": "integer",
            "description": "Number of results per page.",
            "example": 20
          },
          "totalPages": {
            "type": "integer",
            "description": "Total pages for the active filters (`ceil(total / limit)`).",
            "example": 3
          }
        },
        "required": ["data", "total", "page", "limit", "totalPages"]
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid `access_token` cookie.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "statusCode": 401, "message": "Unauthorized" }
          }
        }
      },
      "Forbidden": {
        "description": "Authenticated but insufficient role or not the resource owner.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": { "statusCode": 403, "message": "Forbidden" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found.",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "statusCode": 404,
              "message": "Lifeliner not found",
              "error": "Not Found"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/auth/google": {
      "get": {
        "tags": ["Auth"],
        "summary": "Initiate Google OAuth",
        "description": "Redirects the browser to Google's consent screen. Not called via fetch — navigate the browser directly to this URL.",
        "responses": {
          "302": { "description": "Redirect to Google." }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "tags": ["Auth"],
        "summary": "Google OAuth callback",
        "description": "Google redirects here after the user grants access. Creates the user account on first login (or links the provider to an existing account matched by email). Sets a signed HttpOnly `access_token` cookie, then redirects to `CLIENT_URL/`.",
        "responses": {
          "302": {
            "description": "Login successful — redirects to the client app. The `access_token` cookie is set on this response.",
            "headers": {
              "Set-Cookie": {
                "schema": {
                  "type": "string",
                  "example": "access_token=<signed-jwt>; Path=/; HttpOnly; SameSite=Lax"
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user",
        "description": "Returns the identity decoded from the JWT cookie.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Current authenticated user.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthUser" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/auth/role": {
      "patch": {
        "tags": ["Auth"],
        "summary": "Select role",
        "description": "Sets the role for the authenticated user. Can only be called once — once a role is set, this returns 403.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SelectRoleBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Role updated. Returns the updated user.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthUser" }
              }
            }
          },
          "400": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout",
        "description": "Clears the `access_token` cookie. Returns 204 with no body.",
        "responses": {
          "204": { "description": "Cookie cleared. User is logged out." }
        }
      }
    },
    "/lifeliners": {
      "get": {
        "tags": ["Lifeliners"],
        "summary": "List lifeliners (public)",
        "description": "Returns paginated public lifeliner profiles. All filters are optional and combinable. Never returns `private_picture` or `full_name`.",
        "parameters": [
          {
            "name": "age_groups",
            "in": "query",
            "required": false,
            "description": "Filter to lifeliners who support at least one of the given age groups. Repeat for multiple: `?age_groups=TEENS&age_groups=ADULTS`",
            "schema": {
              "type": "array",
              "items": { "$ref": "#/components/schemas/AgeGroup" }
            },
            "style": "form",
            "explode": true
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "description": "Case-insensitive substring match on `display_name`.",
            "schema": { "type": "string", "example": "alex" }
          },
          {
            "name": "min_age",
            "in": "query",
            "required": false,
            "description": "Minimum lifeliner age (inclusive). Must be between 18 and 120.",
            "schema": { "type": "integer", "minimum": 18, "maximum": 120, "example": 20 }
          },
          {
            "name": "max_age",
            "in": "query",
            "required": false,
            "description": "Maximum lifeliner age (inclusive). Must be between 18 and 120.",
            "schema": { "type": "integer", "minimum": 18, "maximum": 120, "example": 40 }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "description": "Page number (1-based). Defaults to 1.",
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Results per page. Defaults to 20, max 100.",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated lifeliner profiles.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedLifeliners" }
              }
            }
          },
          "400": {
            "description": "Invalid query parameter.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Lifeliners"],
        "summary": "Create lifeliner profile",
        "description": "Creates the caller's lifeliner profile. Requires role `LIFELINER`. Each user can only have one profile.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateLifelinerBody" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Profile created. Returns the full lifeliner record.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Lifeliner" }
              }
            }
          },
          "400": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "409": {
            "description": "A lifeliner profile already exists for this user.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "statusCode": 409,
                  "message": "Lifeliner profile already exists",
                  "error": "Conflict"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Lifeliners"],
        "summary": "Update own lifeliner profile",
        "description": "Partially updates the caller's lifeliner profile. Requires role `LIFELINER`. The profile is identified by the JWT — no ID param needed.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateLifelinerBody" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated lifeliner record.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Lifeliner" }
              }
            }
          },
          "400": {
            "description": "Validation error.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ValidationError" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/lifeliners/me": {
      "get": {
        "tags": ["Lifeliners"],
        "summary": "Get own lifeliner profile",
        "description": "Returns the full lifeliner record for the authenticated user, including private fields (`full_name`, `private_picture`). Requires role `LIFELINER`.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Full lifeliner record for the caller.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Lifeliner" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/lifeliners/private/verification-photo": {
      "get": {
        "tags": ["Lifeliners"],
        "summary": "Get own verification photo",
        "description": "Streams the caller's verification photo. Only the owning lifeliner can access this. Requires role `LIFELINER`.",
        "security": [{ "cookieAuth": [] }],
        "responses": {
          "200": {
            "description": "Image file stream.",
            "content": {
              "image/jpeg": {},
              "image/png": {},
              "image/webp": {}
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/lifeliners/{id}": {
      "get": {
        "tags": ["Lifeliners"],
        "summary": "Get lifeliner profile (public)",
        "description": "Returns a single lifeliner's public profile. Never returns `private_picture` or `full_name`.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "cm9xyz789"
          }
        ],
        "responses": {
          "200": {
            "description": "Public lifeliner profile.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PublicLifeliner" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/lifeliners/upload/profile-picture": {
      "post": {
        "tags": ["Lifeliners"],
        "summary": "Upload profile picture",
        "description": "Replaces the caller's public profile picture. Accepted formats: JPEG, PNG, WebP. Max size: 5 MB. Requires role `LIFELINER`.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Picture updated. Returns the updated id and profile_picture URL.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "profile_picture": { "type": "string", "format": "uri" }
                  },
                  "required": ["id", "profile_picture"]
                }
              }
            }
          },
          "400": {
            "description": "No file provided or unsupported format.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/lifeliners/upload/verification-photo": {
      "post": {
        "tags": ["Lifeliners"],
        "summary": "Upload verification photo",
        "description": "Replaces the caller's private verification photo. Accepted formats: JPEG, PNG, WebP. Max size: 5 MB. Requires role `LIFELINER`. This file is never exposed publicly.",
        "security": [{ "cookieAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": ["file"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Verification photo updated. Returns the lifeliner id.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" }
                  },
                  "required": ["id"]
                }
              }
            }
          },
          "400": {
            "description": "No file provided or unsupported format.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Google OAuth login, role selection, and session management"
    },
    {
      "name": "Lifeliners",
      "description": "Volunteer mental health provider directory"
    }
  ]
}
